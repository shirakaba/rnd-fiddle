{
  "js/ts.experimental.useTsgo": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.enable.oxfmt": true,
  "oxc.enable.oxlint": false,
  "biome.enabled": false,
  "prettier.enable": false,
  "eslint.enable": false,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  }
}

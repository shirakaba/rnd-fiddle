{
  "name": "rndfiddle-monorepo",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/expo-child-process",
    "packages/electron-shim",
    "apps/desktop",
    "apps/web"
  ],
  "scripts": {
    "dev": "sh ./scripts/dev-with-tmux.sh",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "format": "oxfmt",
    "typecheck": "bun run typecheck:native && bun run typecheck:web",
    "typecheck:desktop": "bun run --cwd apps/desktop typecheck",
    "typecheck:web": "bun run --cwd apps/web typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0"
  },
  "lint-staged": {
    "*.{css,html,js,jsx,json,md,ts,tsx}": [
      "oxfmt"
    ]
  },
  "catalog": {
    "react": "19.1.4",
    "react-dom": "^19.0.0",
    "react-native-webview": "^13.16.1",
    "@typescript/native-preview": "^7.0.0-dev.20260319.1"
  },
  "patchedDependencies": {
    "@blueprintjs/core@3.54.0": "patches/@blueprintjs%2Fcore@3.54.0.patch",
    "expo-modules-core@3.0.29": "patches/expo-modules-core@3.0.29.patch"
  }
}

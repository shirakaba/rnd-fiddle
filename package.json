{
  "name": "rndfiddle",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "electron-shim",
    "web"
  ],
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "sh ./scripts/dev-with-tmux.sh",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "format": "oxfmt",
    "typecheck": "bun run typecheck:native && bun run typecheck:web",
    "typecheck:native": "tsgo --noEmit",
    "typecheck:web": "bun run --cwd web typecheck",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "macos": "sh ./scripts/run-macos.sh"
  },
  "dependencies": {
    "dubloon": "^0.0.4",
    "dubloon-electron-shim": "workspace:",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-macos": "0.81.2",
    "react-native-webview": "catalog:"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.1",
    "@react-native/metro-config": "~0.81.0",
    "@rnx-kit/metro-config": "^2.2.4",
    "@types/react": "~19.1.0",
    "@typescript/native-preview": "catalog:",
    "babel-plugin-transform-define": "^2.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0"
  },
  "lint-staged": {
    "*.{css,html,js,jsx,json,md,ts,tsx}": [
      "oxfmt"
    ]
  },
  "catalog": {
    "react": "19.1.4",
    "react-dom": "^19.0.0",
    "react-native-webview": "^13.16.1",
    "@typescript/native-preview": "^7.0.0-dev.20260319.1"
  },
  "patchedDependencies": {
    "@blueprintjs/core@3.54.0": "patches/@blueprintjs%2Fcore@3.54.0.patch",
    "expo-modules-core@3.0.29": "patches/expo-modules-core@3.0.29.patch"
  }
}
